cff-version: 1.2.0
title: "APEX-1: A Best-of-All-Worlds Large Language Model"
message: "If you use APEX-1 in your research, please cite it as below."
type: software
authors:
  - name: "AArambh Dev Hub"
    website: "https://github.com/AArambhDevHub"
